#!/usr/bin/env bash

# 默认挂载根目录。若条目未显式指定本地挂载点，则使用:
#   \$MOUNT_BASE_DIR/<名称>
MOUNT_BASE_DIR="$HOME/mount"

# 挂载项统一格式:
#   名称|用户名|主机|远程路径|本地挂载点|端口
#
# 规则:
#   - 前四项必填: 名称、用户名、主机、远程路径
#   - 本地挂载点可选，不填时默认使用: $MOUNT_BASE_DIR/<名称>
#   - 端口可选，不填时交给 ~/.ssh/config 或 ssh 默认值解析
SSHFS_ENTRIES=(
    "signal-server-home|your-user|signal-server|/home/your-user"
    "signal-server-data|your-user|signal-server|/data|$HOME/mount/signal-server-data"
)

# 重试配置
MAX_RETRY=3
RETRY_DELAY=5

# 网络匹配模式:
#   always   总是允许挂载
#   match    只有命中下面任一规则才允许挂载
NETWORK_MODE="match"

# 任一数组命中即认为当前网络可挂载。可以按需留空。
NETWORK_GATEWAYS=(
    "10.95.64.1"
)

NETWORK_DNS=(
    "10.95.26.32"
)

NETWORK_IP_PREFIXES=(
    "10.95.64"
)

NETWORK_INTERFACES=(
    "utun0"
    "utun1"
)

NETWORK_SSIDS=(
    "XP-OFFICE-WORK"
)

# macOS 下额外追加的 sshfs 选项。
# 默认已启用 noappledouble,noapplexattr 来避免生成 ._ 开头的文件。
# 如需额外选项，可写成:
# MACOS_SSHFS_EXTRA_OPTIONS="nolocalcaches"
MACOS_SSHFS_EXTRA_OPTIONS=""

# 调试开关。设为 1 后会输出更详细的 sshfs/ssh_command 信息。
SSHFS_DEBUG=0
