#!/usr/bin/env bash

set -uo pipefail

APP_NAME="autosshfs"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/${APP_NAME}"
CONFIG_FILE="${AUTOSSHFS_CONFIG:-$CONFIG_DIR/config.sh}"
LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/${APP_NAME}"
LOG_FILE="${AUTOSSHFS_LOG_FILE:-$LOG_DIR/${APP_NAME}.log}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

SSHFS_ENTRIES=()
MOUNT_BASE_DIR="$HOME/mount"
MAX_RETRY=3
RETRY_DELAY=5
NETWORK_MODE="always"
NETWORK_GATEWAYS=()
NETWORK_DNS=()
NETWORK_IP_PREFIXES=()
NETWORK_INTERFACES=()
NETWORK_SSIDS=()
MACOS_SSHFS_EXTRA_OPTIONS=""

detect_os() {
    case "${OSTYPE:-}" in
        darwin*) echo "macos" ;;
        linux*) echo "linux" ;;
        *) echo "unknown" ;;
    esac
}

OS_TYPE="$(detect_os)"

log() {
    local level="$1"
    shift

    mkdir -p "$LOG_DIR" 2>/dev/null || true
    touch "$LOG_FILE" 2>/dev/null || LOG_FILE="/tmp/${APP_NAME}.log"
    printf '[%s] [%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$level" "$*" | tee -a "$LOG_FILE"
}

die() {
    log "ERROR" "$*"
    exit 1
}

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

expand_path() {
    local raw_path="$1"
    eval "printf '%s\n' \"$raw_path\""
}

parse_sshfs_entry() {
    local config="$1"
    local name field2 field3 field4 field5 field6 user host remote_path resolved_local_path resolved_port

    IFS='|' read -r name field2 field3 field4 field5 field6 <<<"$config"

    if [[ "${field2:-}" == /* ]]; then
        user=""
        host="$name"
        remote_path="$field2"

        if [ -n "${field4:-}" ]; then
            resolved_local_path="$field3"
            resolved_port="$field4"
        elif [ -n "${field3:-}" ]; then
            if [[ "$field3" =~ ^[0-9]+$ ]]; then
                resolved_local_path="${MOUNT_BASE_DIR}/${name}"
                resolved_port="$field3"
            else
                resolved_local_path="$field3"
                resolved_port="22"
            fi
        else
            resolved_local_path="${MOUNT_BASE_DIR}/${name}"
            resolved_port="22"
        fi
    else
        user="$field2"
        host="$field3"
        remote_path="$field4"

        if [ -n "${field6:-}" ]; then
            resolved_local_path="$field5"
            resolved_port="$field6"
        elif [ -n "${field5:-}" ]; then
            if [[ "$field5" =~ ^[0-9]+$ ]]; then
                resolved_local_path="${MOUNT_BASE_DIR}/${name}"
                resolved_port="$field5"
            else
                resolved_local_path="$field5"
                resolved_port="22"
            fi
        else
            resolved_local_path="${MOUNT_BASE_DIR}/${name}"
            resolved_port="22"
        fi
    fi

    printf '%s|%s|%s|%s|%s|%s\n' \
        "$name" \
        "$user" \
        "$host" \
        "$remote_path" \
        "$(expand_path "$resolved_local_path")" \
        "$resolved_port"
}

load_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        cat <<EOF
配置文件不存在: $CONFIG_FILE

请先执行:
  autosshfs init-config

或者设置环境变量:
  AUTOSSHFS_CONFIG=/path/to/config.sh
EOF
        exit 1
    fi

    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
}

check_dependencies() {
    if ! command_exists sshfs; then
        if [ "$OS_TYPE" = "macos" ]; then
            die "未找到 sshfs。请先安装 macFUSE 与 sshfs: brew install --cask macfuse && brew install gromgit/fuse/sshfs-mac"
        elif [ "$OS_TYPE" = "linux" ]; then
            die "未找到 sshfs。请先安装依赖: sudo apt-get install -y sshfs"
        else
            die "未找到 sshfs，且当前系统未被支持"
        fi
    fi

    if [ "$OS_TYPE" = "linux" ] && ! command_exists mountpoint; then
        die "未找到 mountpoint。请安装 util-linux"
    fi
}

print_ok() {
    printf '[OK] %s\n' "$*"
}

print_warn() {
    printf '[WARN] %s\n' "$*"
}

print_info() {
    printf '[INFO] %s\n' "$*"
}

print_entry_header() {
    local name="$1"
    printf '[CHECK] %s\n' "$name"
}

ssh_target() {
    local user="$1"
    local host="$2"
    if [ -n "$user" ]; then
        printf '%s@%s' "$user" "$host"
    else
        printf '%s' "$host"
    fi
}

ssh_base_options() {
    printf '%s' "-T -x -o RequestTTY=no -o RemoteCommand=none -o ClearAllForwardings=yes -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new"
}

sshfs_ssh_command() {
    printf '%s' "ssh -T -x -o RequestTTY=no -o RemoteCommand=none -o ClearAllForwardings=yes -o StrictHostKeyChecking=accept-new"
}

ssh_config_check() {
    local name="$1"
    local user="$2"
    local host="$3"
    local port="$4"
    local mode="${5:-doctor}"
    local target output rc resolved_user resolved_host resolved_port

    target="$(ssh_target "$user" "$host")"
    output="$(
        ssh \
            -G \
            -F "${HOME}/.ssh/config" \
            -o BatchMode=yes \
            -o ConnectTimeout=5 \
            -p "$port" \
            "$target" 2>&1
    )"
    rc=$?

    if [ "$rc" -eq 0 ]; then
        resolved_user="$(printf '%s\n' "$output" | awk '/^user / {print $2; exit}')"
        resolved_host="$(printf '%s\n' "$output" | awk '/^hostname / {print $2; exit}')"
        resolved_port="$(printf '%s\n' "$output" | awk '/^port / {print $2; exit}')"

        if [ "$mode" = "doctor" ]; then
            print_ok "[${name}] SSH 配置解析正常: ${target}"
            [ -n "$resolved_user" ] && print_info "[${name}] Resolved User: $resolved_user"
            [ -n "$resolved_host" ] && print_info "[${name}] Resolved HostName: $resolved_host"
            [ -n "$resolved_port" ] && print_info "[${name}] Resolved Port: $resolved_port"
            print_info "[${name}] 如需验证免密登录，请手工执行: ssh ${target}"
        else
            log "INFO" "[${name}] SSH 配置解析正常: ${target}"
            [ -n "$resolved_user" ] && log "INFO" "[${name}] Resolved User: $resolved_user"
            [ -n "$resolved_host" ] && log "INFO" "[${name}] Resolved HostName: $resolved_host"
            [ -n "$resolved_port" ] && log "INFO" "[${name}] Resolved Port: $resolved_port"
        fi
        return 0
    fi

    if [ "$mode" = "doctor" ]; then
        print_warn "[${name}] SSH 配置解析失败: ${target}"
        [ -n "$output" ] && print_info "SSH 输出: $output"
    else
        log "ERROR" "[${name}] SSH 配置解析失败: ${target}"
        [ -n "$output" ] && log "ERROR" "[${name}] SSH 输出: $output"
    fi

    return 1
}

doctor_macos() {
    local failed=0

    if command_exists brew; then
        print_ok "已检测到 Homebrew"
    else
        print_warn "未检测到 Homebrew"
        failed=1
    fi

    if command_exists sshfs; then
        print_ok "已检测到 sshfs"
    else
        print_warn "未检测到 sshfs"
        print_info "可尝试执行: brew install gromgit/fuse/sshfs-mac"
        failed=1
    fi

    if [ -e /Library/Filesystems/macfuse.fs ] || [ -e /Library/Extensions/macfuse.kext ]; then
        print_ok "检测到 macFUSE 文件"
    else
        print_warn "未检测到 macFUSE 安装痕迹"
        print_info "可尝试执行: brew install --cask macfuse"
        failed=1
    fi

    if systemextensionsctl list 2>/dev/null | grep -qi 'macfuse'; then
        print_ok "检测到 macFUSE 系统扩展记录"
    else
        print_warn "未在 systemextensionsctl 中看到 macFUSE"
        print_info "如果刚安装过 macFUSE，可能还需要在 系统设置 > 隐私与安全性 中手动允许"
    fi

    return "$failed"
}

doctor_linux() {
    local failed=0

    if command_exists sshfs; then
        print_ok "已检测到 sshfs"
    else
        print_warn "未检测到 sshfs"
        print_info "Debian/Ubuntu 可执行: sudo apt-get install -y sshfs"
        failed=1
    fi

    if command_exists fusermount || command_exists fusermount3; then
        print_ok "已检测到 fusermount"
    else
        print_warn "未检测到 fusermount/fusermount3"
        failed=1
    fi

    if command_exists mountpoint; then
        print_ok "已检测到 mountpoint"
    else
        print_warn "未检测到 mountpoint，请安装 util-linux"
        failed=1
    fi

    if [ -f /etc/fuse.conf ]; then
        if grep -Eq '^[[:space:]]*user_allow_other' /etc/fuse.conf 2>/dev/null; then
            print_ok "/etc/fuse.conf 已启用 user_allow_other"
        else
            print_warn "/etc/fuse.conf 未启用 user_allow_other，可能影响 allow_other 选项"
        fi
    else
        print_warn "未找到 /etc/fuse.conf"
    fi

    return "$failed"
}

doctor_config() {
    if [ -f "$CONFIG_FILE" ]; then
        print_ok "配置文件存在: $CONFIG_FILE"
    else
        print_warn "配置文件不存在: $CONFIG_FILE"
        print_info "先执行: autosshfs init-config"
        return 1
    fi
    return 0
}

doctor_network() {
    if [ ! -f "$CONFIG_FILE" ]; then
        return 0
    fi

    load_config
    if check_network >/dev/null 2>&1; then
        print_ok "当前网络环境满足挂载条件"
    else
        print_warn "当前网络环境未命中配置规则"
    fi
}

doctor_entries() {
    local config parsed name user host remote_path local_path port failed=0

    if [ ! -f "$CONFIG_FILE" ]; then
        return 0
    fi

    if ! command_exists ssh; then
        print_warn "未检测到 ssh，无法检查每个挂载项的 SSH 免密连接"
        return 1
    fi

    if [ "${#SSHFS_ENTRIES[@]}" -eq 0 ]; then
        print_warn "配置中没有 SSHFS_ENTRIES"
        return 1
    fi

    printf '\n'
    printf 'SSH Entry Checks:\n'

    for config in "${SSHFS_ENTRIES[@]:-}"; do
        parsed="$(parse_sshfs_entry "$config")"
        IFS='|' read -r name user host remote_path local_path port <<<"$parsed"

        print_entry_header "$name"
        print_info "Target: $(ssh_target "$user" "$host"):$port"
        print_info "Remote: $remote_path"
        print_info "Mountpoint: $local_path"

        if [ -d "$local_path" ]; then
            print_ok "[${name}] 本地挂载点已存在"
        else
            print_warn "[${name}] 本地挂载点不存在，挂载时会自动创建"
        fi

        ssh_config_check "$name" "$user" "$host" "$port" "doctor" || failed=1
    done

    return "$failed"
}

doctor() {
    local failed=0

    printf 'OS: %s\n' "$OS_TYPE"
    printf 'Config: %s\n' "$CONFIG_FILE"
    printf '\n'

    doctor_config || failed=1
    case "$OS_TYPE" in
        macos) doctor_macos || failed=1 ;;
        linux) doctor_linux || failed=1 ;;
        *)
            print_warn "当前系统未支持自动诊断"
            failed=1
            ;;
    esac
    doctor_network
    doctor_entries || failed=1
    return "$failed"
}

network_check_disabled() {
    [ "${NETWORK_MODE:-always}" = "always" ]
}

check_network_macos() {
    local gateway dns prefix iface ssid current_ssid

    for ssid in "${NETWORK_SSIDS[@]:-}"; do
        current_ssid="$(
            /System/Library/PrivateFrameworks/Apple80211.framework/Versions/Current/Resources/airport -I 2>/dev/null |
                awk -F': ' '/ SSID/ {print $2}'
        )"
        if [ -n "$current_ssid" ] && [ "$current_ssid" = "$ssid" ]; then
            log "INFO" "检测到匹配的 Wi-Fi SSID: $ssid"
            return 0
        fi
    done

    for gateway in "${NETWORK_GATEWAYS[@]:-}"; do
        if netstat -nr 2>/dev/null | grep -q "default.*${gateway}"; then
            log "INFO" "检测到匹配网关: $gateway"
            return 0
        fi
    done

    for dns in "${NETWORK_DNS[@]:-}"; do
        if scutil --dns 2>/dev/null | grep -q "$dns"; then
            log "INFO" "检测到匹配 DNS: $dns"
            return 0
        fi
    done

    for prefix in "${NETWORK_IP_PREFIXES[@]:-}"; do
        if ifconfig 2>/dev/null | grep -q "inet ${prefix}"; then
            log "INFO" "检测到匹配 IP 前缀: $prefix"
            return 0
        fi
    done

    for iface in "${NETWORK_INTERFACES[@]:-}"; do
        if ifconfig 2>/dev/null | grep -q "^${iface}"; then
            log "INFO" "检测到匹配接口: $iface"
            return 0
        fi
    done

    return 1
}

check_network_linux() {
    local gateway dns prefix iface

    for gateway in "${NETWORK_GATEWAYS[@]:-}"; do
        if ip route 2>/dev/null | grep -q "default via ${gateway}"; then
            log "INFO" "检测到匹配网关: $gateway"
            return 0
        fi
    done

    for dns in "${NETWORK_DNS[@]:-}"; do
        if grep -q "nameserver ${dns}" /etc/resolv.conf 2>/dev/null; then
            log "INFO" "检测到匹配 DNS: $dns"
            return 0
        fi
    done

    for prefix in "${NETWORK_IP_PREFIXES[@]:-}"; do
        if ip addr 2>/dev/null | grep -q "inet ${prefix}"; then
            log "INFO" "检测到匹配 IP 前缀: $prefix"
            return 0
        fi
    done

    for iface in "${NETWORK_INTERFACES[@]:-}"; do
        if ip link show "$iface" >/dev/null 2>&1; then
            log "INFO" "检测到匹配接口: $iface"
            return 0
        fi
    done

    return 1
}

check_network() {
    if network_check_disabled; then
        log "INFO" "NETWORK_MODE=always，跳过网络环境检测"
        return 0
    fi

    log "INFO" "开始检测网络环境"

    if [ "$OS_TYPE" = "macos" ]; then
        check_network_macos && return 0
    elif [ "$OS_TYPE" = "linux" ]; then
        check_network_linux && return 0
    fi

    log "WARN" "当前网络环境未命中配置规则，跳过挂载"
    return 1
}

is_mounted() {
    local mount_point="$1"

    if [ "$OS_TYPE" = "linux" ]; then
        mountpoint -q "$mount_point"
    else
        mount | grep -q " on ${mount_point} "
    fi
}

is_sshfs_mounted() {
    local mount_point="$1"

    if [ "$OS_TYPE" = "macos" ]; then
        mount | grep -E -q "on ${mount_point} \((macfuse|osxfuse|sshfs)"
    else
        mount | grep -q "on ${mount_point} type fuse.sshfs"
    fi
}

mountpoint_has_local_residue() {
    local mount_point="$1"

    [ -d "$mount_point" ] || return 1
    [ -n "$(find "$mount_point" -mindepth 1 -maxdepth 1 2>/dev/null | head -n 1)" ]
}

sshfs_options_for_entry() {
    local name="$1"

    if [ "$OS_TYPE" = "macos" ]; then
        printf '%s' "reconnect,ServerAliveInterval=15,ServerAliveCountMax=3,follow_symlinks,defer_permissions,noappledouble,noapplexattr,volname=${name}${MACOS_SSHFS_EXTRA_OPTIONS:+,${MACOS_SSHFS_EXTRA_OPTIONS}}"
    else
        printf '%s' "reconnect,ServerAliveInterval=15,ServerAliveCountMax=3,follow_symlinks,allow_other,default_permissions"
    fi
}

mount_entry() {
    local config="$1"
    local retry="${2:-0}"
    local parsed name user host remote_path local_path port options target ssh_cmd

    parsed="$(parse_sshfs_entry "$config")"
    IFS='|' read -r name user host remote_path local_path port <<<"$parsed"
    options="$(sshfs_options_for_entry "$name")"
    target="$(ssh_target "$user" "$host")"
    ssh_cmd="$(sshfs_ssh_command)"

    if is_sshfs_mounted "$local_path"; then
        log "INFO" "[${name}] 已挂载: $local_path"
        return 0
    fi

    mkdir -p "$local_path" || {
        log "ERROR" "[${name}] 无法创建挂载点: $local_path"
        return 1
    }

    if mountpoint_has_local_residue "$local_path"; then
        log "WARN" "[${name}] 挂载点目录当前包含本地残留内容: $local_path"
        log "WARN" "[${name}] 如果这是上次异常卸载后的残留，请先确认未挂载，再清理目录内容"
    fi

    log "INFO" "[${name}] 挂载目标: ${target}:${remote_path}"
    log "INFO" "[${name}] 本地挂载点: $local_path"
    log "INFO" "[${name}] 端口: $port"

    if command_exists ssh; then
        ssh_config_check "$name" "$user" "$host" "$port" "mount" || return 1
    fi

    log "INFO" "[${name}] 开始执行 sshfs"
    if sshfs "${target}:${remote_path}" "$local_path" -p "$port" -o "$options" -o "ssh_command=${ssh_cmd}" 2>>"$LOG_FILE"; then
        if is_sshfs_mounted "$local_path"; then
            log "INFO" "[${name}] 挂载成功"
            return 0
        fi

        log "ERROR" "[${name}] sshfs 命令返回成功，但挂载点未处于 sshfs 挂载状态"
        log "ERROR" "[${name}] 请检查 $local_path 是否存在残留目录内容、系统弹窗授权、或 macFUSE/sshfs 异常"
    fi

    log "WARN" "[${name}] sshfs 挂载失败"
    log "WARN" "[${name}] 可先手工验证: ssh -p ${port} ${target}"
    log "WARN" "[${name}] 若 SSH 正常，再手工验证: sshfs ${target}:${remote_path} ${local_path} -p ${port}"
    if [ "$retry" -lt "$MAX_RETRY" ]; then
        retry=$((retry + 1))
        log "INFO" "[${name}] ${RETRY_DELAY}s 后重试 (${retry}/${MAX_RETRY})"
        sleep "$RETRY_DELAY"
        mount_entry "$config" "$retry"
        return $?
    fi

    log "ERROR" "[${name}] 重试后仍失败"
    return 1
}

umount_entry() {
    local config="$1"
    local parsed name user host remote_path local_path port

    parsed="$(parse_sshfs_entry "$config")"
    IFS='|' read -r name user host remote_path local_path port <<<"$parsed"

    if ! is_mounted "$local_path"; then
        log "INFO" "[${name}] 未挂载: $local_path"
        return 0
    fi

    log "INFO" "[${name}] 卸载: $local_path"
    if [ "$OS_TYPE" = "macos" ]; then
        umount "$local_path" 2>>"$LOG_FILE" || umount -f "$local_path" 2>>"$LOG_FILE"
    else
        fusermount -u "$local_path" 2>>"$LOG_FILE" || fusermount -uz "$local_path" 2>>"$LOG_FILE"
    fi

    if is_mounted "$local_path"; then
        log "ERROR" "[${name}] 卸载失败"
        return 1
    fi

    log "INFO" "[${name}] 卸载成功"
    return 0
}

mount_all() {
    check_network || return 1

    local config failed=0
    for config in "${SSHFS_ENTRIES[@]:-}"; do
        mount_entry "$config" || failed=1
    done
    return "$failed"
}

umount_all() {
    local config failed=0
    for config in "${SSHFS_ENTRIES[@]:-}"; do
        umount_entry "$config" || failed=1
    done
    return "$failed"
}

find_entry() {
    local target="$1"
    local config name user host remote_path local_path port

    for config in "${SSHFS_ENTRIES[@]:-}"; do
        IFS='|' read -r name user host remote_path local_path port <<<"$config"
        if [ "$name" = "$target" ]; then
            printf '%s\n' "$config"
            return 0
        fi
    done
    return 1
}

mount_one() {
    local target="$1"
    local config

    check_network || return 1
    config="$(find_entry "$target")" || die "未找到配置: $target"
    mount_entry "$config"
}

umount_one() {
    local target="$1"
    local config

    config="$(find_entry "$target")" || die "未找到配置: $target"
    umount_entry "$config"
}

auto_remount() {
    check_network || return 1

    local config parsed name user host remote_path local_path port failed=0
    for config in "${SSHFS_ENTRIES[@]:-}"; do
        parsed="$(parse_sshfs_entry "$config")"
        IFS='|' read -r name user host remote_path local_path port <<<"$parsed"
        if ! is_sshfs_mounted "$local_path"; then
            log "WARN" "[${name}] 未挂载，开始补挂载"
            mount_entry "$config" || failed=1
        fi
    done
    return "$failed"
}

show_status() {
    local config parsed name user host remote_path local_path port state

    printf 'OS: %s\n' "$OS_TYPE"
    printf 'Config: %s\n' "$CONFIG_FILE"
    if check_network >/dev/null 2>&1; then
        printf 'Network: matched\n'
    else
        printf 'Network: not matched\n'
    fi
    printf '\n'
    printf '%-24s %-12s %-40s\n' "NAME" "STATUS" "MOUNTPOINT"
    printf '%-24s %-12s %-40s\n' "------------------------" "------------" "----------------------------------------"

    for config in "${SSHFS_ENTRIES[@]:-}"; do
        parsed="$(parse_sshfs_entry "$config")"
        IFS='|' read -r name user host remote_path local_path port <<<"$parsed"
        if is_sshfs_mounted "$local_path"; then
            state="mounted"
        else
            state="unmounted"
        fi
        printf '%-24s %-12s %-40s\n' "$name" "$state" "$local_path"
    done
}

list_entries() {
    local config parsed name user host remote_path local_path port

    for config in "${SSHFS_ENTRIES[@]:-}"; do
        parsed="$(parse_sshfs_entry "$config")"
        IFS='|' read -r name user host remote_path local_path port <<<"$parsed"
        printf '%s -> %s:%s => %s\n' "$name" "$(ssh_target "$user" "$host")" "$remote_path" "$local_path"
    done
}

init_config() {
    local example_path="__INSTALL_PREFIX__/share/autosshfs/config.sh.example"

    if [ ! -f "$example_path" ]; then
        example_path="$(cd "$SCRIPT_DIR/.." && pwd)/share/autosshfs/config.sh.example"
    fi

    mkdir -p "$CONFIG_DIR"
    if [ -f "$CONFIG_FILE" ]; then
        printf '配置已存在: %s\n' "$CONFIG_FILE"
        return 0
    fi

    cp "$example_path" "$CONFIG_FILE"
    printf '已生成配置模板: %s\n' "$CONFIG_FILE"
}

show_help() {
    cat <<EOF
用法: ${APP_NAME} <command> [name]

命令:
  init-config     初始化配置模板到 ~/.config/autosshfs/config.sh
  doctor          检查依赖、配置和网络条件
  check           同 doctor
  mount-all       挂载全部配置
  umount-all      卸载全部配置
  auto-remount    检查并补挂载未挂载项
  mount <name>    按名称挂载
  umount <name>   按名称卸载
  status          显示状态
  list            列出所有配置
  help            显示帮助

配置文件:
  $CONFIG_FILE
EOF
}

main() {
    local cmd="${1:-help}"

    case "$cmd" in
        init-config)
            init_config
            ;;
        doctor|check)
            doctor
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            load_config
            case "$cmd" in
                mount)
                    check_dependencies
                    [ -n "${2:-}" ] || die "请指定 name"
                    mount_one "$2"
                    ;;
                umount)
                    check_dependencies
                    [ -n "${2:-}" ] || die "请指定 name"
                    umount_one "$2"
                    ;;
                mount-all|auto-remount|status|list)
                    check_dependencies
                    case "$cmd" in
                        mount-all) mount_all ;;
                        auto-remount) auto_remount ;;
                        status) show_status ;;
                        list) list_entries ;;
                    esac
                    ;;
                umount-all)
                    check_dependencies
                    umount_all
                    ;;
                *)
                    show_help
                    exit 1
                    ;;
            esac
            ;;
    esac
}

main "$@"
